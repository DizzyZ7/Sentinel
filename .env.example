POSTGRES_DB=sentinel
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@db:5432/sentinel
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
LLM_ENABLED=true
LLM_MAX_CONCURRENCY=3
LLM_TIMEOUT_SECONDS=90
LLM_MAX_RETRIES=3
LLM_MAX_CONTEXT_CHARS=40000
MAX_LLM_CANDIDATES=30
MAX_PATCH_BYTES=64000
MAX_PATCH_CHANGED_LINES=200
DATA_DIR=/data
ALLOWED_GIT_HOSTS=github.com,gitlab.com,bitbucket.org
MAX_ARCHIVE_BYTES=52428800
MAX_EXTRACTED_BYTES=209715200
MAX_ARCHIVE_FILES=5000
MAX_SOURCE_FILE_BYTES=1000000
